ENVIRONMENT=development
DATABASE_URL=sqlite:///./intent_signals.db
# Set to require x-api-key on all API routes except /api/health.
API_KEY=
CORS_ORIGINS=["http://localhost:8000"]

# Optional. Without this, outreach uses the deterministic evidence-backed template.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MINUTES=30
MAX_RSS_ITEMS_PER_POLL=50
REQUEST_TIMEOUT_SECONDS=15
